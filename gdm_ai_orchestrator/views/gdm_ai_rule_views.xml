<odoo>
    <record id="view_gdm_ai_rule_tree" model="ir.ui.view">
        <field name="name">gdm.ai.rule.tree</field>
        <field name="model">gdm.ai.rule</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active"
                  decoration-danger="risk_level == 'high'"
                  decoration-warning="risk_level == 'medium'">
                <field name="sequence" widget="handle"/>
                <field name="active" optional="show"/>
                <field name="name"/>
                <field name="code"/>
                <field name="entity_model"/>
                <field name="check_type"/>
                <field name="field_name"/>
                <field name="threshold"
                       attrs="{'invisible': [('check_type', '!=', 'amount_consistency')]}"/>
                <field name="risk_level"/>
                <field name="decision_on_fail"/>
                <field name="required_action_on_fail"/>
                <field name="trigger_onchain_on_pass"/>
                <field name="message"/>
            </tree>
        </field>
    </record>

    <record id="view_gdm_ai_rule_form" model="ir.ui.view">
        <field name="name">gdm.ai.rule.form</field>
        <field name="model">gdm.ai.rule</field>
        <field name="arch" type="xml">
            <form string="AI Rule">
                <sheet>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="Rule name..."/></h1>
                        <div class="o_row">
                            <field name="code" placeholder="technical_code"
                                   style="font-family: monospace; font-size: 13px;"/>
                        </div>
                    </div>
                    <group>
                        <group string="Identity &amp; Scope">
                            <field name="entity_model"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Check Configuration">
                            <field name="check_type"/>
                            <field name="field_name"
                                   placeholder="e.g. supplier_id, date_start"
                                   attrs="{'required': [('check_type', '=', 'field_required')],
                                           'invisible': [('check_type', 'in', ['date_range', 'custom'])]}"/>
                            <field name="threshold"
                                   attrs="{'invisible': [('check_type', '!=', 'amount_consistency')],
                                           'required': [('check_type', '=', 'amount_consistency')]}"
                                   help="Multiplier for contract amount. E.g. 1.2 = 120%."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Outcome on Failure" name="outcome">
                            <group>
                                <group string="Decision">
                                    <field name="risk_level"/>
                                    <field name="decision_on_fail"/>
                                    <field name="required_action_on_fail"/>
                                </group>
                                <group string="Message &amp; Blockchain">
                                    <field name="message"
                                           placeholder="Message shown in decision log..."/>
                                    <field name="trigger_onchain_on_pass"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="description" nolabel="1"
                                   placeholder="Optional description..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_gdm_ai_rule" model="ir.actions.act_window">
        <field name="name">AI Rules</field>
        <field name="res_model">gdm.ai.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

    <menuitem id="menu_gdm_ai_rule"
              name="AI Rules"
              parent="gdm_contract.menu_contract_config_root"
              action="action_gdm_ai_rule"
              sequence="45"/>
</odoo>
