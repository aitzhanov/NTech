<odoo>
    <record id="view_contract_type_tree" model="ir.ui.view">
        <field name="name">contract.type.tree</field>
        <field name="model">contract.type</field>
        <field name="arch" type="xml">
            <tree string="Contract Types">
                <field name="name"/>
                <field name="code" optional="show"/>
                <field name="is_purchase" optional="show"/>
                <field name="is_lease" optional="show"/>
                <field name="is_supply" optional="show"/>
                <field name="active" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_contract_type_form" model="ir.ui.view">
        <field name="name">contract.type.form</field>
        <field name="model">contract.type</field>
        <field name="arch" type="xml">
            <form string="Contract Type">
                <sheet>
                    <group>
                        <group string="Identity">
                            <field name="name"/>
                            <field name="code"/>
                            <field name="active"/>
                        </group>
                        <group string="Type flags">
                            <field name="is_purchase"/>
                            <field name="is_lease"/>
                            <field name="is_supply"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_contract_type" model="ir.actions.act_window">
        <field name="name">Contract Types</field>
        <field name="res_model">contract.type</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
