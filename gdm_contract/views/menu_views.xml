<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Main GDM app menu -->
    <menuitem
        id="menu_gdm_contract_root"
        name="GDM Contracts"
        sequence="10"
        web_icon="gdm_contract,static/description/icon.png"
    />

    <!-- Contracts action -->
    <record id="action_gdm_contract_contracts" model="ir.actions.act_window">
        <field name="name">Contracts</field>
        <field name="res_model">contract.contract</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first GDM contract
            </p>
        </field>
    </record>

    <!-- Contract Stages action -->
    <record id="action_gdm_contract_stages" model="ir.actions.act_window">
        <field name="name">Contract Stages</field>
        <field name="res_model">contract.stage</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Contract Types action -->
    <record id="action_gdm_contract_types" model="ir.actions.act_window">
        <field name="name">Contract Types</field>
        <field name="res_model">contract.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Dashboard action -->
    <record id="action_gdm_blockchain_dashboard" model="ir.actions.act_window">
        <field name="name">Blockchain Dashboard</field>
        <field name="res_model">contract.contract</field>
        <field name="view_mode">kanban,tree,form</field>
    </record>

    <!-- Main submenus -->
    <menuitem
        id="menu_gdm_contract_contracts"
        name="Contracts"
        parent="menu_gdm_contract_root"
        action="action_gdm_contract_contracts"
        sequence="10"
    />

    <menuitem
        id="menu_gdm_contract_dashboard"
        name="Blockchain Dashboard"
        parent="menu_gdm_contract_root"
        action="action_gdm_blockchain_dashboard"
        sequence="20"
    />

    <!-- Configuration menu -->
    <menuitem
        id="menu_gdm_contract_configuration"
        name="Configuration"
        parent="menu_gdm_contract_root"
        sequence="90"
    />

    <menuitem
        id="menu_gdm_contract_stages"
        name="Contract Stages"
        parent="menu_gdm_contract_configuration"
        action="action_gdm_contract_stages"
        sequence="10"
    />

    <menuitem
        id="menu_gdm_contract_types"
        name="Contract Types"
        parent="menu_gdm_contract_configuration"
        action="action_gdm_contract_types"
        sequence="20"
    />

</odoo>